# ================================
# Register model
# ================================

from sagemaker.sklearn.model import SKLearnModel
from sagemaker.model_metrics import ModelMetrics, MetricsSource

model_package_group_name = "iris-sklearn-model-group"

# Create SKLearn model from training artifact
model = SKLearnModel(
    model_data=sklearn_estimator.model_data,
    role=role,
    entry_point=training_path,
    framework_version=FRAMEWORK_VERSION,
    py_version="py3",
    sagemaker_session=sagemaker_session
)

# Get evaluation report S3 path
evaluation_s3_uri = (
    eval_processor.latest_job.describe()
    ["ProcessingOutputConfig"]["Outputs"][0]["S3Output"]["S3Uri"]
    + "/evaluation.json"
)

# Attach evaluation metrics to the model package
model_metrics = ModelMetrics(
    model_statistics=MetricsSource(
        s3_uri=evaluation_s3_uri,
        content_type="application/json"
    )
)

# Register the trained model in SageMaker Model Registry
model_package = model.register(
    content_types=["text/csv"],
    response_types=["text/csv"],
    inference_instances=["ml.t2.medium", "ml.m5.large"],
    transform_instances=["ml.m5.large"],
    model_package_group_name=model_package_group_name,
    approval_status="PendingManualApproval",
    model_metrics=model_metrics
)

print("Model registered successfully.")
print(model_package.model_package_arn)
